    given-names: "Abiodun"
    email: "asojobi@unilag.edu.ng"
    affiliation: "University of Lagos, Nigeria"
keywords:
  - physics-informed neural networks
  - glomerular filtration
  - kidney disease
  - computational nephrology
  - convection-diffusion-reaction
  - Poiseuille flow
  - chronic kidney disease
  - PyTorch
